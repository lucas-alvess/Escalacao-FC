{
  "appId": "com.escalacaofc.app",
  "appName": "Escalação FC",
  "webDir": "public",
  "server": {
    "url": "https://escalacao-fc.web.app",
    "cleartext": false
  },
  "android": {
    "backgroundColor": "#050c0a",
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#050c0a",
      "androidSplashResourceName": "splash",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    }
  }
}