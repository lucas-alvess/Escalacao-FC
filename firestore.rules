rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────────
    // Helpers
    // ─────────────────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isCollabMember(teamId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/collab_teams/$(teamId)/members/$(request.auth.uid));
    }

    function isCollabOwner(teamId) {
      return isAuth() &&
        get(/databases/$(database)/documents/collab_teams/$(teamId)).data.ownerUid == request.auth.uid;
    }


    // ─────────────────────────────────────────────────────────────────────────
    // users/{uid}
    // ─────────────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /teams/{teamId} {
        allow read, write: if isOwner(uid);

        match /players/{playerId}   { allow read, write: if isOwner(uid); }
        match /lineups/{lineupId}   { allow read, write: if isOwner(uid); }
        match /matches/{matchId}    { allow read, write: if isOwner(uid); }
        match /stats/{statId}       { allow read, write: if isOwner(uid); }
      }

      match /mensalistas/{agendaId} {
        allow read, write: if isOwner(uid);

        match /mensalidades/{mesAno} {
          allow read, write: if isOwner(uid);
        }
      }

      // Índice de times colaborativos que o usuário participa
      match /collab_refs/{teamId} {
        allow read: if isOwner(uid);
        // Unificado em um único allow para create/delete evitar ambiguidade
        allow create: if isOwner(uid);
        allow delete: if isOwner(uid) ||
          (isAuth() && get(/databases/$(database)/documents/collab_teams/$(teamId)).data.ownerUid == request.auth.uid);
      }

      // Índice de agendas colaborativas que o usuário participa
      // CORREÇÃO: unificado create/delete e adicionado allow update para
      // permitir que o próprio usuário atualize sua ref (reparação de estado parcial)
      match /collab_agenda_refs/{agendaId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid);
        allow delete: if isOwner(uid) ||
          (isAuth() && get(/databases/$(database)/documents/collab_agendas/$(agendaId)).data.ownerUid == request.auth.uid);
      }
    }


    // ─────────────────────────────────────────────────────────────────────────
    // collab_teams/{teamId}
    // ─────────────────────────────────────────────────────────────────────────
    match /collab_teams/{teamId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isCollabMember(teamId);
      allow delete: if isCollabOwner(teamId);

      match /players/{playerId}   { allow read, write: if isCollabMember(teamId); }
      match /lineups/{lineupId}   { allow read, write: if isCollabMember(teamId); }
      match /matches/{matchId}    { allow read, write: if isCollabMember(teamId); }
      match /stats/{statId}       { allow read, write: if isCollabMember(teamId); }

      match /members/{memberUid} {
        allow read: if isCollabMember(teamId) || (isAuth() && request.auth.uid == memberUid);
        allow create: if isAuth() && (request.auth.uid == memberUid || isCollabOwner(teamId));
        allow update: if isCollabOwner(teamId);
        allow delete: if isAuth() && (
          request.auth.uid == memberUid ||
          (isCollabOwner(teamId) && memberUid != request.auth.uid)
        );
      }
    }


    // ─────────────────────────────────────────────────────────────────────────
    // collab_invites/{code}
    // ─────────────────────────────────────────────────────────────────────────
    match /collab_invites/{code} {
      allow read: if isAuth();
      allow create: if isAuth() &&
        request.resource.data.ownerUid == request.auth.uid &&
        get(/databases/$(database)/documents/collab_teams/$(request.resource.data.teamId)).data.ownerUid == request.auth.uid;
      allow update, delete: if isAuth() &&
        get(/databases/$(database)/documents/collab_teams/$(resource.data.teamId)).data.ownerUid == request.auth.uid;
    }


    // ─────────────────────────────────────────────────────────────────────────
    // shared_teams/{code}
    // ─────────────────────────────────────────────────────────────────────────
    match /shared_teams/{code} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if false;
      allow delete: if isAuth() && resource.data.ownerUid == request.auth.uid;
    }


    // ─────────────────────────────────────────────────────────────────────────
    // collab_agendas/{agendaId}
    // ─────────────────────────────────────────────────────────────────────────
    match /collab_agendas/{agendaId} {

      // CORREÇÃO: extraídas como funções locais para garantir avaliação correta
      // e evitar dependência circular entre isAgendaMember e isAgendaOwner
      function isAgendaMember() {
        return isAuth() &&
          exists(/databases/$(database)/documents/collab_agendas/$(agendaId)/members/$(request.auth.uid));
      }

      function isAgendaOwner() {
        return isAuth() &&
          get(/databases/$(database)/documents/collab_agendas/$(agendaId)).data.ownerUid == request.auth.uid;
      }

      // Qualquer autenticado pode ler o doc raiz (necessário para aceitar convite)
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.ownerUid == request.auth.uid;
      // CORREÇÃO: dono também pode atualizar (ex: salvar players/info como owner)
      allow update: if isAgendaMember() || isAgendaOwner();
      allow delete: if isAgendaOwner();

      match /mensalidades/{mesAno} {
        // CORREÇÃO: isAgendaOwner separado para garantir acesso mesmo antes de
        // isAgendaMember retornar true (lag de propagação do Firestore)
        allow read, write: if isAgendaMember() || isAgendaOwner();
      }

      match /members/{memberUid} {
        // Leitura: membros veem todos; não-membros só veem o próprio doc
        // (necessário para o app verificar se já é membro antes de entrar)
        allow read: if isAuth() && (isAgendaMember() || request.auth.uid == memberUid);

        // CORREÇÃO: qualquer autenticado pode se adicionar como membro
        // (o código de convite já é a "senha" — validado no app)
        // Restrição: só pode criar o seu próprio doc (uid == memberUid)
        allow create: if isAuth() && (
          request.auth.uid == memberUid || isAgendaOwner()
        );

        allow update: if isAgendaOwner();

        allow delete: if isAuth() && (
          request.auth.uid == memberUid ||
          (isAgendaOwner() && memberUid != request.auth.uid)
        );
      }
    }


    // ─────────────────────────────────────────────────────────────────────────
    // collab_agenda_invites/{code}
    // ─────────────────────────────────────────────────────────────────────────
    match /collab_agenda_invites/{code} {
      allow read: if isAuth();
      allow create: if isAuth() &&
        request.resource.data.ownerUid == request.auth.uid &&
        get(/databases/$(database)/documents/collab_agendas/$(request.resource.data.agendaId)).data.ownerUid == request.auth.uid;
      allow update, delete: if isAuth() &&
        get(/databases/$(database)/documents/collab_agendas/$(resource.data.agendaId)).data.ownerUid == request.auth.uid;
    }


    // ─────────────────────────────────────────────────────────────────────────
    // Negar tudo o que não foi explicitamente permitido acima
    // ─────────────────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
